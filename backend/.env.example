# TechnoElevate Backend — Environment Variables
# Copy this file to .env and fill in your values.
#
# First-time DB: creates tables (including `users`) + demo data — run from backend/:
#   npm run db:setup
#   (same as `npm run seed`)

# Express server port
PORT=6000

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techno_elevate
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# JWT — change this to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# Allowed frontend origins (comma-separated). Add each origin the browser uses, e.g.:
# FRONTEND_URL=http://localhost:7000,http://103.182.211.219:7000
FRONTEND_URL=http://localhost:7000

# OpenAI — required for AI case study generation
OPENAI_API_KEY=sk-your-openai-api-key-here

# SMTP — for sending reports via email (works with Gmail App Passwords, SendGrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=TechnoElevate <your-email@gmail.com>

# File uploads directory (relative to backend/)
UPLOADS_DIR=uploads
