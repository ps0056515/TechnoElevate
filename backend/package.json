{
  "name": "techno-elevate-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "start:prod": "NODE_ENV=production node server.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:reload": "pm2 reload techno-elevate",
    "pm2:stop": "pm2 stop techno-elevate",
    "pm2:logs": "pm2 logs techno-elevate",
    "pm2:monit": "pm2 monit",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "db:setup": "node seed.js",
    "db:migrate": "node migrate.js",
    "build:frontend":  "cd ../frontend && npm run build",
    "deploy":          "npm run build:frontend && npm run pm2:reload",
    "template":        "node generate-template.js",
    "onboard":         "node onboard-excel.js",
    "onboard:reset":   "node onboard-excel.js --reset",
    "onboard:dry-run": "node onboard-excel.js --dry-run",
    "test":            "jest --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.3",
    "express-rate-limit": "^7.5.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
