# Optional. Override API origin (HTTPS, different host, or not port 6000).
# Local `vite` dev: leave unset — /api is proxied; then set VITE_DEV_PROXY to your API URL (e.g. http://localhost:6001).
# If the proxy port is wrong, API calls can return the SPA’s index.html and you will see: Unexpected token '<'.
# Production build: if unset, the app uses the same hostname as the page with port 6000.
# VITE_API_URL=https://api.example.com
VITE_API_URL=
# Vite dev only — where to proxy /api (must match the running backend port).
# VITE_DEV_PROXY=http://localhost:6001
